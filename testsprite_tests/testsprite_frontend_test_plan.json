  {
    "id": "TC001",
    "title": "Successful sign-in redirects user to Profile page",
    "description": "Verifies a user can log in with valid email/password and is redirected to the protected profile page.",
    "category": "User Login",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /signin"
      },
      {
        "type": "assertion",
        "description": "Verify text \"Sign In\" is visible"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_USER}}\" into the email field"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_PASSWORD}}\" into the password field"
      },
      {
        "type": "action",
        "description": "Click on the \"Login\" button"
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/profile\""
      },
      {
        "type": "assertion",
        "description": "Verify text \"Profile\" is visible"
      }
    ]
  },
